# Copia a .env en local. No subir .env a Git.
#
# Jenkins: sin .env en el clone, define estas mismas claves en el job
# (Environment variables / credenciales enmascaradas) para docker compose.

JWT_SECRET=cambiar-en-produccion
JWT_EXPIRE_IN=24H
JWT_REFRESH_SECRET=cambiar-en-produccion
PORT=3000
WS_PORT=3001
MONGO_HOST_PORT=27017

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/test?retryWrites=true&w=majority

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://localhost:8081
